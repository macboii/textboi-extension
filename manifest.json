{
  "manifest_version": 3,
  "name": "TextBoi",
  "version": "0.1.0",

  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "identity",
    "contextMenus"
  ],

  "host_permissions": [
    "https://worker.textboi.ai/*",
    "https://*.supabase.co/*"
  ],

  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },

  "commands": {
    "translate": {
      "suggested_key": {
        "default": "Alt+Shift+T",
        "mac": "Command+Shift+T"
      },
      "description": "Translate selected text"
    },
    "correct": {
      "suggested_key": {
        "default": "Alt+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Correct selected text"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,   
      "js": [
        "content/overlay.js",
        "content/bubble.js",
        "content/content.js"
      ],
      "css": ["content/styles.css"]
    }
  ],

  "action": {
    "default_popup": "popup/popup.html"
  }
}
