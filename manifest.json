{
  "manifest_version": 3,
  "name": "TextBoi - AI Writing Assistant",
  "version": "0.1.3",

  "permissions": [
    "tabs",
    "storage",
    "identity",
    "contextMenus",
    "clipboardWrite",
    "clipboardRead"
  ],

  "host_permissions": [
    "https://worker.textboi.ai/*",
    "https://*.supabase.co/*",
    "https://supabase-rest-api.bangcoderpro.workers.dev/*",
    "https://stripe-worker.bangcoderpro.workers.dev/*",
    "https://textboi.ai/*"
  ],

  "background": {
    "service_worker": "dist/background/background.js",
    "type": "module"
  },

  "commands": {
    "translate": {
      "suggested_key": {
        "default": "Alt+Shift+T",
        "mac": "Command+Shift+T"
      },
      "description": "Translate selected text"
    },
    "correct": {
      "suggested_key": {
        "default": "Alt+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Correct selected text"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content/content.js"],
      "css": ["content/styles.css"]
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["<all_urls>"]
    },
    {
      "resources": ["billing-success.html", "billing-success.js"],
      "matches": ["https://textboi.ai/*"]
    }
  ]
}
